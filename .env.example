DATABASE_HOST=127.0.0.1
DATABASE_PORT=3306
DATABASE_USER=portfolio
DATABASE_PASSWORD=portfolio
DATABASE_NAME=portfolio
ADMIN_PASSWORD=admin123

# Contato (Orçamento) — SMTP
# Você pode configurar um SMTP na sua VPS para envio real.
# Em ambiente de desenvolvimento (NODE_ENV != production), o endpoint entra em modo mock.
CONTACT_SMTP_HOST=
CONTACT_SMTP_PORT=587
CONTACT_SMTP_USER=
CONTACT_SMTP_PASS=
CONTACT_SMTP_FROM=
CONTACT_SMTP_TO=
CONTACT_SMTP_SECURE=false

# Se preferir, use também:
# CONTACT_TO_EMAIL=seu-email@dominio.com
CONTACT_TO_EMAIL=
