# Este arquivo é um MODELO.
# Em produção, o Gitea Actions gera `.env.production` na VPS a partir dos Secrets.
#
# Secrets obrigatórios no Gitea:
#   ADMIN_PASSWORD
#   MYSQL_ROOT_PASSWORD
#   DATABASE_PASSWORD
#   (+ SSH_HOST, SSH_USER, SSH_PRIVATE_KEY)
#
# Secrets opcionais:
#   DATABASE_NAME, DATABASE_USER
#   CONTACT_SMTP_*, CONTACT_TO_EMAIL

MYSQL_ROOT_PASSWORD=
DATABASE_NAME=portfolio
DATABASE_USER=portfolio
DATABASE_PASSWORD=
ADMIN_PASSWORD=

CONTACT_SMTP_HOST=
CONTACT_SMTP_PORT=587
CONTACT_SMTP_USER=
CONTACT_SMTP_PASS=
CONTACT_SMTP_FROM=
CONTACT_SMTP_TO=
CONTACT_TO_EMAIL=
CONTACT_SMTP_SECURE=false
